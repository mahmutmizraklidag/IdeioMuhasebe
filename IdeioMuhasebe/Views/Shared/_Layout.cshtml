@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@{
    var tokens = Antiforgery.GetAndStoreTokens(Context);
}
<!doctype html>
<html lang="tr" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"] - Ideio Muhasebe</title>

    <link rel="icon" type="image/png" sizes="32x32" href="@Url.Content("~/img/fav/dark-favicon-32x32.png")" media="(prefers-color-scheme: light)">
    <link rel="icon" type="image/png" sizes="16x16" href="@Url.Content("~/img/fav/dark-favicon-16x16.png")" media="(prefers-color-scheme: light)">
    <link rel="apple-touch-icon" href="@Url.Content("~/img/fav/dark-apple-touch-icon.png")" media="(prefers-color-scheme: light)">

    <link rel="icon" type="image/png" sizes="32x32" href="@Url.Content("~/img/fav/light-favicon-32x32.png")" media="(prefers-color-scheme: dark)">
    <link rel="icon" type="image/png" sizes="16x16" href="@Url.Content("~/img/fav/light-favicon-16x16.png")" media="(prefers-color-scheme: dark)">
    <link rel="apple-touch-icon" href="@Url.Content("~/img/fav/light-apple-touch-icon.png")" media="(prefers-color-scheme: dark)">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">


    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <input type="hidden" id="__RequestVerificationToken" value="@tokens.RequestToken" />

    <div class="app-shell">
        <aside class="sidebar">
            <div class="brand">
                <span class="logo-dot"></span>
                <span class="fw-semibold">Ideio Muhasebe</span>
            </div>

            <nav class="nav flex-column gap-1 mt-3">
                <a class="nav-link" href="/"><i class="bi bi-house"></i><span>Anasayfa</span></a>
                <a class="nav-link" href="/DebtTypes"><i class="bi bi-tags"></i><span>Borç Kategorileri</span></a>
                <a class="nav-link" href="/Debts"><i class="bi bi-list-check"></i><span>Borçlar</span></a>
                <a class="nav-link" href="/Payments"><i class="bi bi-arrow-left-right"></i><span>Ödemeler</span></a>
                <a class="nav-link" href="/IncomeTypes"><i class="bi bi-tag"></i><span>Gelir Kategorileri</span></a>
                <a class="nav-link" href="/Incomes"><i class="bi bi-cash-coin"></i><span>Gelirler</span></a>
                <a class="nav-link" href="/IncomePayments"><i class="bi bi-arrow-left-right"></i><span>Gelir Tahsilat</span></a>
                <a class="nav-link" href="/Statistics"><i class="bi bi-bar-chart"></i><span>İstatistik</span></a>
                <a class="nav-link" href="/Users"><i class="bi bi-people"></i><span>Kullanıcılar</span></a>
            </nav>

            <div class="mt-auto pt-3">
                <div class="small text-muted mb-2">Giriş: <b>@User.Identity?.Name</b></div>
                <a class="btn btn-outline-light w-100" href="/Account/Logout">
                    <i class="bi bi-box-arrow-right"></i> Çıkış
                </a>
            </div>
        </aside>

        <main class="content">
            <div class="topbar">
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-light" id="btnToggleSidebar" type="button">
                        <i class="bi bi-list"></i>
                    </button>
                    <div class="fw-semibold">@ViewData["Title"]</div>
                </div>
                <div class="text-muted small">@DateTime.Now.ToString("dd.MM.yyyy")</div>
            </div>

            <div class="container-fluid py-3">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/menu.js" asp-append-version="true"></script>
    <script src="~/js/app.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>