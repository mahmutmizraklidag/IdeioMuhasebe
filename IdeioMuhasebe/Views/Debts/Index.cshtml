@{
    ViewData["Title"] = "Borçlar";
}
@Html.AntiForgeryToken()

<div class="card card-soft mb-3">
    <div class="card-body d-flex flex-wrap gap-2 align-items-end">
        <div>
            <label class="form-label small text-muted">Başlangıç</label>
            <input type="date" class="form-control" id="fromDate">
        </div>
        <div>
            <label class="form-label small text-muted">Bitiş</label>
            <input type="date" class="form-control" id="toDate">
        </div>
        <div style="min-width:240px">
            <label class="form-label small text-muted">Kategori</label>
            <select class="form-select" id="typeFilter"></select>
        </div>
        <div style="min-width:200px">
            <label class="form-label small text-muted">Durum</label>
            <select class="form-select" id="paidFilter">
                <option value="">Tümü</option>
                <option value="0">Ödenmedi</option>
                <option value="1">Ödendi</option>
            </select>
        </div>
        <button class="btn btn-primary ms-auto" id="btnApply">
            <i class="bi bi-funnel"></i> Filtrele
        </button>
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-lg-8">
        <div class="card card-soft">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr class="text-muted small">
                                <th>Tarih</th>
                                <th>Kategori</th>
                                <th>Borç</th>
                                <th>Ödenecek Yer</th>
                                <th class="text-end">Tutar</th>
                                <th class="text-end">Durum</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody id="debtBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card card-soft sticky-side">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <div class="fw-semibold" id="sideTitle">Borç Ekle</div>
                    <button class="btn btn-primary btn-sm" id="btnNewDebt" title="Yeni borç">
                        <i class="bi bi-plus-lg"></i>
                    </button>
                </div>
                <div class="text-muted small mb-3">Sağdaki formdan hızlıca ekle/düzenle.</div>

                <input type="hidden" id="debtId" value="0" />

                <div class="mb-2">
                    <label class="form-label">Kategori</label>
                    <select class="form-select" id="debtTypeId"></select>
                </div>

                <div class="mb-2">
                    <label class="form-label">Borç Adı</label>
                    <input class="form-control" id="debtName" maxlength="120" />
                </div>

                <div class="row g-2">
                    <div class="col-6">
                        <label class="form-label">Tutar</label>
                        <input type="number" step="0.01" class="form-control" id="debtAmount" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Son Ödeme</label>
                        <input type="date" class="form-control" id="debtDueDate" />
                    </div>
                </div>

                <div class="mt-2">
                    <label class="form-label">Ödenecek Yer</label>
                    <input class="form-control" id="debtPayee" maxlength="120" />
                </div>

                <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" id="debtIsPaid">
                    <label class="form-check-label">Ödendi</label>
                </div>

                <!-- ✅ YENİ: Yinelenen + Kaç dönem -->
                <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" id="debtIsRecurring">
                    <label class="form-check-label">Yinelenen</label>
                </div>

                <div class="mt-2 d-none" id="wrapDebtPeriod">
                    <label class="form-label">Kaç dönem yenilensin?</label>
                    <input type="number" min="1" class="form-control" id="debtPeriodCount" placeholder="Boş bırakılırsa sınırsız" />
                    <div class="small text-muted mt-1">Örn: 12 = 12 ay boyunca her ay oluşur.</div>
                </div>

                <div class="text-danger small mt-2 d-none" id="debtErr">Zorunlu alanları doldurun.</div>

                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-primary flex-fill" id="btnSaveDebt">Kaydet</button>
                    <button class="btn btn-light" id="btnResetDebt" title="Temizle">Temizle</button>
                </div>
            </div>
        </div>
    </div>
</div>

<button class="fab d-lg-none" id="btnAddDebt" title="Borç Ekle"><i class="bi bi-plus-lg"></i></button>

@section Scripts {
    <script src="~/js/debts.js" asp-append-version="true"></script>
}