@{
    ViewData["Title"] = "Gelirler";
}
@Html.AntiForgeryToken()

<div class="card card-soft mb-3">
    <div class="card-body d-flex flex-wrap gap-2 align-items-end">
        <div>
            <label class="form-label small text-muted">Başlangıç</label>
            <input type="date" class="form-control" id="fromDate">
        </div>
        <div>
            <label class="form-label small text-muted">Bitiş</label>
            <input type="date" class="form-control" id="toDate">
        </div>
        <div style="min-width:240px">
            <label class="form-label small text-muted">Kategori</label>
            <select class="form-select" id="typeFilter"></select>
        </div>
        <div style="min-width:200px">
            <label class="form-label small text-muted">Durum</label>
            <select class="form-select" id="receivedFilter">
                <option value="">Tümü</option>
                <option value="0">Tahsil Edilmedi</option>
                <option value="1">Tahsil Edildi</option>
            </select>
        </div>

        <button class="btn btn-primary ms-auto" id="btnApply">
            <i class="bi bi-funnel"></i> Filtrele
        </button>
    </div>
</div>

<div class="row g-3">
    <!-- LEFT: TABLE -->
    <div class="col-12 col-lg-8">
        <div class="card card-soft">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr class="text-muted small">
                                <th>Tarih</th>
                                <th>Kategori</th>
                                <th>Gelir</th>
                                <th>Tahsil Eden / Kaynak</th>
                                <th class="text-end">Tutar</th>
                                <th class="text-end">Durum</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody id="incomeBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT: ADD / EDIT PANEL -->
    <div class="col-12 col-lg-4">
        <div class="card card-soft sticky-side">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <div class="fw-semibold" id="sideTitle">Gelir Ekle</div>
                    <button class="btn btn-primary btn-sm" id="btnNewIncome" title="Yeni gelir">
                        <i class="bi bi-plus-lg"></i>
                    </button>
                </div>
                <div class="text-muted small mb-3">Sağdaki formdan hızlıca ekle/düzenle.</div>

                <input type="hidden" id="incomeId" value="0" />

                <div class="mb-2">
                    <label class="form-label">Kategori</label>
                    <select class="form-select" id="incomeTypeId"></select>
                </div>

                <div class="mb-2">
                    <label class="form-label">Gelir Adı</label>
                    <input class="form-control" id="incomeName" maxlength="120" />
                </div>

                <div class="row g-2">
                    <div class="col-6">
                        <label class="form-label">Net Tutar</label>
                        <input type="number" step="0.01" class="form-control" id="incomeNetAmount" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Vergi Tutarı</label>
                        <input type="number" step="0.01" class="form-control" id="incomeTaxAmount" />
                    </div>
                </div>

                <div class="mt-2">
                    <label class="form-label">Toplam Tutar</label>
                    <input type="number" step="0.01" class="form-control" id="incomeAmount" readonly />
                </div>

                <div class="row g-2 mt-1">
                    <div class="col-6">
                        <label class="form-label">Tarih</label>
                        <input type="date" class="form-control" id="incomeDueDate" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Kaynak / Ödeyen</label>
                        <textarea class="form-control" id="incomePayer" maxlength="120"></textarea>
                    </div>
                </div>

                <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" id="incomeIsReceived">
                    <label class="form-check-label">Tahsil Edildi</label>
                </div>

                <!-- ✅ YENİ: Yinelenen + Kaç dönem -->
                <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" id="incomeIsRecurring">
                    <label class="form-check-label">Yinelenen</label>
                </div>

                <div class="mt-2 d-none" id="wrapIncomePeriod">
                    <label class="form-label">Kaç dönem yenilensin?</label>
                    <input type="number" min="1" class="form-control" id="incomePeriodCount" placeholder="Boş bırakılırsa sınırsız" />
                    <div class="small text-muted mt-1">Örn: 12 = 12 ay boyunca her ay oluşur.</div>
                </div>

                <div class="text-danger small mt-2 d-none" id="incomeErr">Zorunlu alanları doldurun.</div>

                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-primary flex-fill" id="btnSaveIncome">Kaydet</button>
                    <button class="btn btn-light" id="btnResetIncome" title="Temizle">Temizle</button>
                </div>
            </div>
        </div>
    </div>
</div>

<button class="fab d-lg-none" id="btnAddIncome" title="Gelir Ekle"><i class="bi bi-plus-lg"></i></button>

@section Scripts {
    <script src="~/js/incomes.js" asp-append-version="true"></script>
}