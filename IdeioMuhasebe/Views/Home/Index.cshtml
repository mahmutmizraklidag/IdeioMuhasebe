@{
    ViewData["Title"] = "Anasayfa";
}
@Html.AntiForgeryToken()
<style>
    .category-popover {
        position: fixed !important;
        z-index: 1080 !important;
        width: 300px;
        background: var(--bs-body-bg) !important;
        opacity: 1 !important;
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 12px 28px rgba(0,0,0,.28);
    }
</style>
<style>
    .category-popover {
        position: fixed !important;
        z-index: 1080 !important;
        width: 300px;
        background: var(--bs-body-bg) !important;
        opacity: 1 !important;
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 12px 28px rgba(0,0,0,.28);
    }

    .upcoming-table-wrap {
        max-height: 520px;
        overflow-y: auto;
        overflow-x: auto;
    }

        .upcoming-table-wrap thead th {
            position: sticky;
            top: 0;
            z-index: 2;
            background: var(--bs-body-bg);
        }

    @@media (max-width: 991.98px) {
        .upcoming-table-wrap {
            max-height: 380px;
        }
    }
</style>
<div class="card card-soft mb-3">
    <div class="card-body d-flex flex-wrap gap-2 align-items-end">
        <div>
            <label class="form-label small text-muted">Başlangıç</label>
            <input type="date" class="form-control" id="fromDate">
        </div>
        <div>
            <label class="form-label small text-muted">Bitiş</label>
            <input type="date" class="form-control" id="toDate">
        </div>

        <div style="min-width:240px">
            <label class="form-label small text-muted">Gider Kategorisi</label>
            <select class="form-select" id="debtTypeFilter"></select>
        </div>

        <div style="min-width:240px">
            <label class="form-label small text-muted">Gelir Kategorisi</label>
            <select class="form-select" id="incomeTypeFilter"></select>
        </div>

        <button class="btn btn-primary ms-auto" id="btnApply">
            <i class="bi bi-funnel"></i> Filtrele
        </button>
    </div>
</div>
<!-- GELİR KARTLARI -->
<div class="row g-3 mb-3">
    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Toplam Gelir</div>
                <div class="fs-4 fw-semibold text-success" id="cIncTotal">0 ₺</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Tahsil Edilen</div>
                <div class="fs-4 fw-semibold text-success" id="cIncReceived">0 ₺</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Beklenen Gelir</div>
                <div class="fs-4 fw-semibold text-success" id="cIncRemaining">0 ₺</div>
            </div>
        </div>
    </div>
</div>
<!-- GİDER KARTLARI -->
<div class="row g-3 mb-3">
    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Toplam Gider</div>
                <div class="fs-4 fw-semibold text-danger" id="cExpTotal">0 ₺</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Ödenen Gider</div>
                <div class="fs-4 fw-semibold text-danger" id="cExpPaid">0 ₺</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Kalan Gider</div>
                <div class="fs-4 fw-semibold text-danger" id="cExpRemaining">0 ₺</div>
            </div>
        </div>
    </div>
</div>



<!-- SEÇİLENLER -->
<div class="row g-3 mb-3 d-none" id="selectedCardsRow">
    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Seçilen Toplam Gelir</div>
                <div class="fs-4 fw-semibold text-success" id="cSelInc">0 ₺</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Seçilen Toplam Gider</div>
                <div class="fs-4 fw-semibold text-danger" id="cSelExp">0 ₺</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Seçilen Gelir - Gider</div>
                <div class="fs-4 fw-semibold text-primary" id="cSelDiff">0 ₺</div>
            </div>
        </div>
    </div>
</div>

<!-- Yaklaşanlar -->
<div class="row g-3">
    <div class="col-12 col-lg-6">
        <div class="card card-soft">
            <div class="card-body position-relative">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="fw-semibold">Yaklaşan Giderler</div>
                    <div class="text-muted small"><span id="expCount">0</span> kayıt</div>
                </div>

                <!-- Gider kategori popup -->
                <div class="card shadow-sm d-none category-popover" id="expCatPanel">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="fw-semibold small">Gider Kategorileri</div>
                            <button type="button" class="btn btn-sm btn-light" id="expCatClear">Tümü</button>
                        </div>

                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="expCatSelectAll">
                            <label class="form-check-label small" for="expCatSelectAll">Tümünü seç</label>
                        </div>

                        <div id="expCatList" class="d-flex flex-column gap-1 small" style="max-height:220px; overflow:auto;"></div>
                    </div>
                </div>

                <div class="table-responsive upcoming-table-wrap">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr class="text-muted small">
                                <th style="width:70px">
                                    <div class="form-check m-0">
                                        <input class="form-check-input" type="checkbox" id="expSelectAll">
                                        <label class="form-check-label small" for="expSelectAll">Tümü</label>
                                    </div>
                                </th>
                                <th>Tarih</th>
                                <th>
                                    <button type="button"
                                            class="btn btn-link p-0 text-decoration-none link-secondary small"
                                            id="expCatToggle" style="color:#e5e7ebbf !important;">
                                        Kategori
                                    </button>
                                </th>
                                <th>Gider</th>
                                <th class="text-end">Tutar</th>
                                <th class="text-end">Kalan</th>
                            </tr>
                        </thead>
                        <tbody id="expBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card card-soft">
            <div class="card-body position-relative">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="fw-semibold">Yaklaşan Gelirler</div>
                    <div class="text-muted small"><span id="incCount">0</span> kayıt</div>
                </div>

                <!-- Gelir kategori popup -->
                <div class="card shadow-sm d-none category-popover" id="incCatPanel">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="fw-semibold small">Gelir Kategorileri</div>
                            <button type="button" class="btn btn-sm btn-light" id="incCatClear">Tümü</button>
                        </div>

                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="incCatSelectAll">
                            <label class="form-check-label small" for="incCatSelectAll">Tümünü seç</label>
                        </div>

                        <div id="incCatList" class="d-flex flex-column gap-1 small" style="max-height:220px; overflow:auto;"></div>
                    </div>
                </div>

                <div class="table-responsive upcoming-table-wrap">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr class="text-muted small">
                                <th style="width:70px">
                                    <div class="form-check m-0">
                                        <input class="form-check-input" type="checkbox" id="incSelectAll">
                                        <label class="form-check-label small" for="incSelectAll">Tümü</label>
                                    </div>
                                </th>
                                <th>Tarih</th>
                                <th>
                                    <button type="button"
                                            class="btn btn-link p-0 text-decoration-none link-secondary small"
                                            id="incCatToggle" style="color:#e5e7ebbf !important;">
                                          
                                        Kategori
                                    </button>
                                </th>
                                <th>Gelir</th>
                                <th class="text-end">Tutar</th>
                                <th class="text-end">Kalan</th>
                            </tr>
                        </thead>
                        <tbody id="incBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/home.js" asp-append-version="true"></script>
}