@{
    ViewData["Title"] = "Anasayfa";
}
@Html.AntiForgeryToken()

<style>
    .summary-table-wrap {
        overflow-x: auto;
    }

    .summary-table {
        min-width: 980px;
        margin-bottom: 0;
    }

        .summary-table th,
        .summary-table td {
            vertical-align: middle;
            white-space: nowrap;
        }

        .summary-table th {
            font-size: .82rem;
            color: var(--bs-secondary-color);
        }

    .summary-category-link {
        color: inherit;
        text-decoration: none;
        font-weight: 600;
    }

        .summary-category-link:hover {
            text-decoration: underline;
        }

    .summary-count-badge {
        min-width: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: .42rem .55rem;
        border-radius: 999px;
        font-weight: 700;
        font-size: .80rem;
        color: #fff;
    }

    .summary-count-red {
        background: #dc3545;
    }

    .summary-count-yellow {
        background: #ffc107;
        color: #212529;
    }

    .summary-count-green {
        background: #198754;
    }

    .summary-status-paid,
    .summary-status-unpaid {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: .42rem .7rem;
        border-radius: 999px;
        font-size: .8rem;
        font-weight: 700;
    }

    .summary-status-paid {
        background: rgba(25,135,84,.12);
        color: #198754;
        border: 1px solid rgba(25,135,84,.25);
    }

    .summary-status-unpaid {
        background: rgba(220,53,69,.12);
        color: #dc3545;
        border: 1px solid rgba(220,53,69,.25);
    }

    .summary-money {
        font-variant-numeric: tabular-nums;
        font-weight: 600;
    }

    .summary-tabs {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .summary-tab-btn {
        border: 1px solid rgba(255,255,255,.12);
        background: var(--bs-body-bg);
        color: var(--bs-body-color);
        border-radius: 999px;
        padding: .6rem 1rem;
        font-weight: 600;
        transition: all .2s ease;
    }

        .summary-tab-btn.active {
            background: var(--bs-primary);
            color: #fff;
            border-color: var(--bs-primary);
            box-shadow: 0 8px 20px rgba(13,110,253,.22);
        }

    @@media (max-width: 767.98px) {
        .summary-table {
            min-width: 900px;
        }
    }
</style>

<div class="card card-soft mb-3">
    <div class="card-body d-flex flex-wrap gap-2 align-items-end">
        <div>
            <label class="form-label small text-muted">Başlangıç</label>
            <input type="date" class="form-control" id="fromDate">
        </div>

        <div>
            <label class="form-label small text-muted">Bitiş</label>
            <input type="date" class="form-control" id="toDate">
        </div>

        <div style="min-width:240px">
            <label class="form-label small text-muted">Gider Kategorisi</label>
            <select class="form-select" id="debtTypeFilter"></select>
        </div>

        <div style="min-width:240px">
            <label class="form-label small text-muted">Gelir Kategorisi</label>
            <select class="form-select" id="incomeTypeFilter"></select>
        </div>

        <button class="btn btn-primary ms-auto" id="btnApply">
            <i class="bi bi-funnel"></i> Filtrele
        </button>
    </div>
</div>

<div class="card card-soft mb-3">
    <div class="card-body">
        <div class="summary-tabs">
            <button type="button" class="summary-tab-btn active" data-summary-tab="all">Tümü</button>
            <button type="button" class="summary-tab-btn" data-summary-tab="expense">Gider</button>
            <button type="button" class="summary-tab-btn" data-summary-tab="income">Gelir</button>
        </div>
    </div>
</div>

<div class="card card-soft mb-3" id="expenseSummaryCard">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="fw-semibold">Gider Özeti</div>
            <div class="text-muted small"><span id="expenseCategoryCount">0</span> kategori</div>
        </div>

        <div class="summary-table-wrap">
            <table class="table summary-table align-middle">
                <thead>
                    <tr>
                        <th>Gider Kategorisi</th>
                        <th class="text-end">Toplam Miktar</th>
                        <th class="text-end">Ödenen Miktar</th>
                        <th class="text-end">Kalan Miktar</th>
                        <th class="text-center">Geçen</th>
                        <th class="text-center">Bugün</th>
                        <th class="text-center">Diğer</th>
                        <th class="text-center">Durum</th>
                    </tr>
                </thead>
                <tbody id="expenseSummaryBody"></tbody>
            </table>
        </div>
    </div>
</div>

<div class="card card-soft mb-4" id="incomeSummaryCard">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="fw-semibold">Gelir Özeti</div>
            <div class="text-muted small"><span id="incomeCategoryCount">0</span> kategori</div>
        </div>

        <div class="summary-table-wrap">
            <table class="table summary-table align-middle">
                <thead>
                    <tr>
                        <th>Gelir Kategorisi</th>
                        <th class="text-end">Toplam Miktar</th>
                        <th class="text-end">Ödenen Miktar</th>
                        <th class="text-end">Kalan Miktar</th>
                        <th class="text-center">Geçen</th>
                        <th class="text-center">Bugün</th>
                        <th class="text-center">Diğer</th>
                        <th class="text-center">Durum</th>
                    </tr>
                </thead>
                <tbody id="incomeSummaryBody"></tbody>
            </table>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Toplam Gider</div>
                <div class="fs-4 fw-semibold text-danger" id="cExpTotal">0 ₺</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Ödenen Gider</div>
                <div class="fs-4 fw-semibold text-danger" id="cExpPaid">0 ₺</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Kalan Gider</div>
                <div class="fs-4 fw-semibold text-danger" id="cExpRemaining">0 ₺</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Toplam Gelir</div>
                <div class="fs-4 fw-semibold text-success" id="cIncTotal">0 ₺</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Tahsil Edilen</div>
                <div class="fs-4 fw-semibold text-success" id="cIncReceived">0 ₺</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Beklenen Gelir</div>
                <div class="fs-4 fw-semibold text-success" id="cIncRemaining">0 ₺</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/home.js" asp-append-version="true"></script>
}