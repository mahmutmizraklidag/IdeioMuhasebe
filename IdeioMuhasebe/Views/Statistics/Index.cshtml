@{
    ViewData["Title"] = "İstatistik";
}
@Html.AntiForgeryToken()

<div class="card card-soft mb-3">
    <div class="card-body d-flex flex-wrap gap-2 align-items-end">
        <div>
            <label class="form-label small text-muted">Başlangıç</label>
            <input type="date" class="form-control" id="fromDate">
        </div>
        <div>
            <label class="form-label small text-muted">Bitiş</label>
            <input type="date" class="form-control" id="toDate">
        </div>

        <div style="min-width:220px">
            <label class="form-label small text-muted">Mod</label>
            <select class="form-select" id="mode">
                <option value="expense">Gider</option>
                <option value="income">Gelir</option>
                <option value="compare" selected>Karşılaştır</option>
            </select>
        </div>

        <!-- GİDER -->
        <div style="min-width:240px" id="wrapDebtType">
            <label class="form-label small text-muted">Gider Kategorisi</label>
            <select class="form-select" id="debtTypeFilter"></select>
        </div>

        <div style="min-width:220px" id="wrapExpenseStatus">
            <label class="form-label small text-muted">Gider Durumu</label>
            <select class="form-select" id="expenseStatus">
                <option value="total" selected>Toplam</option>
                <option value="paid">Ödenen</option>
                <option value="unpaid">Ödenmeyen</option>
            </select>
        </div>

        <!-- GİDER TİPİ -->
        <div style="min-width:220px" id="wrapExpenseKind">
            <label class="form-label small text-muted">Gider Tipi</label>
            <select class="form-select" id="expenseKind">
                <option value="total" selected>Toplam Gider</option>
                <option value="normal">Normal Gider</option>
                <option value="tax_total">Toplam Vergi</option>
                <option value="tax_debt">Gider Vergisi</option>
                <option value="tax_income">Gelir Vergisi</option>
            </select>
        </div>

        <!-- GELİR -->
        <div style="min-width:240px" id="wrapIncomeType">
            <label class="form-label small text-muted">Gelir Kategorisi</label>
            <select class="form-select" id="incomeTypeFilter"></select>
        </div>

        <div style="min-width:220px" id="wrapIncomeStatus">
            <label class="form-label small text-muted">Gelir Durumu</label>
            <select class="form-select" id="incomeStatus">
                <option value="total" selected>Toplam</option>
                <option value="paid">Tahsil Edilen</option>
                <option value="unpaid">Tahsil Edilmeyen</option>
            </select>
        </div>

        <button class="btn btn-primary ms-auto" id="btnApply">
            <i class="bi bi-funnel"></i> Filtrele
        </button>
    </div>
</div>

<div class="row g-3">
    <!-- Line -->
    <div class="col-12">
        <div class="card card-soft">
            <div class="card-body">
                <div class="fw-semibold mb-2">Aylık Çizgisel</div>
                <div class="chart-wrap">
                    <canvas id="dailyChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Ay ay bar (compare modunda) -->
    <div class="col-12 d-none" id="monthBarWrap">
        <div class="card card-soft">
            <div class="card-body">
                <div class="fw-semibold mb-2">Ay Ay Gelir / Gider</div>
                <div class="chart-wrap">
                    <canvas id="monthBarChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Total bar (compare modunda) -->
    <div class="col-12 d-none" id="barWrap">
        <div class="card card-soft">
            <div class="card-body">
                <div class="fw-semibold mb-2">Gelir / Gider (Toplam)</div>
                <div class="chart-wrap">
                    <canvas id="barChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Tek donut -->
    <div class="col-12" id="singleDonutWrap">
        <div class="card card-soft">
            <div class="card-body">
                <div class="fw-semibold mb-2">Dağılım</div>
                <div class="chart-wrap chart-wrap--donut">
                    <canvas id="typeChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Compare modunda iki donut -->
    <div class="col-12 d-none" id="compareDonutsWrap">
        <div class="row g-3">
            <div class="col-12 col-lg-6">
                <div class="card card-soft">
                    <div class="card-body">
                        <div class="fw-semibold mb-2">Gider Dağılımı</div>
                        <div class="chart-wrap chart-wrap--donut">
                            <canvas id="expTypeChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-6">
                <div class="card card-soft">
                    <div class="card-body">
                        <div class="fw-semibold mb-2">Gelir Dağılımı</div>
                        <div class="chart-wrap chart-wrap--donut">
                            <canvas id="incTypeChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ✅ NEW: Özel Karşılaştırma (Sütun) -->
    <div class="col-12">
        <div class="card card-soft">
            <div class="card-body">
                <div class="fw-semibold mb-2">Özel Karşılaştırma (Sütun)</div>

                <div class="row g-3">
                    <!-- A -->
                    <div class="col-12 col-lg-6">
                        <div class="border rounded-3 p-3">
                            <div class="fw-semibold mb-2">A</div>

                            <label class="form-label small text-muted">Ne?</label>
                            <select class="form-select mb-2" id="aMetric">
                                <option value="income_total">Ciro</option>
                                <option value="expense_total">Gider</option>
                                <option value="tax_debt">Gider Vergisi</option>
                                <option value="tax_income">Gelir Vergisi</option>
                            </select>

                            <div class="row g-2">
                                <div class="col-6">
                                    <label class="form-label small text-muted">Başlangıç</label>
                                    <input type="date" class="form-control" id="aFrom">
                                </div>
                                <div class="col-6">
                                    <label class="form-label small text-muted">Bitiş</label>
                                    <input type="date" class="form-control" id="aTo">
                                </div>
                            </div>

                            <div class="row g-2 mt-2">
                                <div class="col-6">
                                    <label class="form-label small text-muted">Gider Kategorisi</label>
                                    <select class="form-select" id="aDebtType"></select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label small text-muted">Gider Durumu</label>
                                    <select class="form-select" id="aExpenseStatus">
                                        <option value="total" selected>Toplam</option>
                                        <option value="paid">Ödenen</option>
                                        <option value="unpaid">Ödenmeyen</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row g-2 mt-2">
                                <div class="col-6">
                                    <label class="form-label small text-muted">Gelir Kategorisi</label>
                                    <select class="form-select" id="aIncomeType"></select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label small text-muted">Gelir Durumu</label>
                                    <select class="form-select" id="aIncomeStatus">
                                        <option value="total" selected>Toplam</option>
                                        <option value="paid">Tahsil Edilen</option>
                                        <option value="unpaid">Tahsil Edilmeyen</option>
                                    </select>
                                </div>
                            </div>

                            <div class="small text-muted mt-2">
                                Not: Seçtiğin “Ne?” değerine göre bazı filtreler otomatik görmezden gelinir.
                            </div>
                        </div>
                    </div>

                    <!-- B -->
                    <div class="col-12 col-lg-6">
                        <div class="border rounded-3 p-3">
                            <div class="fw-semibold mb-2">B</div>

                            <label class="form-label small text-muted">Ne?</label>
                            <select class="form-select mb-2" id="bMetric">
                                <option value="income_total">Ciro</option>
                                <option value="expense_total">Gider</option>
                                <option value="tax_debt">Gider Vergisi</option>
                                <option value="tax_income">Gelir Vergisi</option>
                            </select>

                            <div class="row g-2">
                                <div class="col-6">
                                    <label class="form-label small text-muted">Başlangıç</label>
                                    <input type="date" class="form-control" id="bFrom">
                                </div>
                                <div class="col-6">
                                    <label class="form-label small text-muted">Bitiş</label>
                                    <input type="date" class="form-control" id="bTo">
                                </div>
                            </div>

                            <div class="row g-2 mt-2">
                                <div class="col-6">
                                    <label class="form-label small text-muted">Gider Kategorisi</label>
                                    <select class="form-select" id="bDebtType"></select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label small text-muted">Gider Durumu</label>
                                    <select class="form-select" id="bExpenseStatus">
                                        <option value="total" selected>Toplam</option>
                                        <option value="paid">Ödenen</option>
                                        <option value="unpaid">Ödenmeyen</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row g-2 mt-2">
                                <div class="col-6">
                                    <label class="form-label small text-muted">Gelir Kategorisi</label>
                                    <select class="form-select" id="bIncomeType"></select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label small text-muted">Gelir Durumu</label>
                                    <select class="form-select" id="bIncomeStatus">
                                        <option value="total" selected>Toplam</option>
                                        <option value="paid">Tahsil Edilen</option>
                                        <option value="unpaid">Tahsil Edilmeyen</option>
                                    </select>
                                </div>
                            </div>

                            <div class="small text-muted mt-2">
                                Örn: A=Şubat Ödenen Gider, B=Mart Ödenmeyen Gider gibi.
                            </div>
                        </div>
                    </div>

                    <div class="col-12 d-flex justify-content-end">
                        <button class="btn btn-primary" id="btnCompareBar">
                            <i class="bi bi-arrow-left-right"></i> Karşılaştır
                        </button>
                    </div>
                </div>

                <div class="chart-wrap mt-3" style="height:260px">
                    <canvas id="customCompareChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="~/js/stats.js" asp-append-version="true"></script>
}