@model LoginVm
@{
    Layout = null;
    ViewData["Title"] = "Giriş";
}
<!doctype html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Giriş - Ideio Muhasebe</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-bg">
    <div class="auth-card">
        <div class="mb-3">
            <div class="d-flex align-items-center gap-2 mb-1">
                <span class="logo-dot"></span>
                <span class="fw-semibold">Ideio Muhasebe</span>
            </div>
            <div class="text-muted small">Devam etmek için giriş yapın</div>
        </div>

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="mb-2">
                <label class="form-label">Kullanıcı Adı</label>
                <input class="form-control" asp-for="Username" />
                <span class="text-danger small" asp-validation-for="Username"></span>
            </div>

            <div class="mb-2">
                <label class="form-label">Şifre</label>
                <input class="form-control" asp-for="Password" />
                <span class="text-danger small" asp-validation-for="Password"></span>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2 small mt-2">
                    @Html.ValidationSummary()
                </div>
            }

            <button class="btn btn-primary w-100 mt-2">Giriş Yap</button>

           
        </form>
    </div>
</body>
</html>