@{
    ViewData["Title"] = "Kategori Detay";
    var id = (int)ViewBag.DebtTypeId;
    var name = (string)ViewBag.DebtTypeName;
}
@Html.AntiForgeryToken()

<div class="d-flex align-items-center justify-content-between mb-2">
    <div>
        <div class="text-muted small">Kategori</div>
        <div class="h4 mb-0">@name</div>
    </div>
    <a class="btn btn-light" href="/DebtTypes"><i class="bi bi-arrow-left"></i> Geri</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-12 col-md-4"><div class="card card-soft"><div class="card-body"><div class="text-muted small">Toplam</div><div class="h3 mb-0" id="cTotal">₺0</div></div></div></div>
    <div class="col-12 col-md-4"><div class="card card-soft"><div class="card-body"><div class="text-muted small">Ödenen</div><div class="h3 mb-0 text-success" id="cPaid">₺0</div></div></div></div>
    <div class="col-12 col-md-4"><div class="card card-soft"><div class="card-body"><div class="text-muted small">Kalan</div><div class="h3 mb-0 text-danger" id="cRemaining">₺0</div></div></div></div>
</div>

<div class="card card-soft mb-3">
    <div class="card-body d-flex flex-wrap gap-2 align-items-end">
        <input type="hidden" id="debtTypeId" value="@id" />
        <div>
            <label class="form-label small text-muted">Başlangıç</label>
            <input type="date" class="form-control" id="fromDate">
        </div>
        <div>
            <label class="form-label small text-muted">Bitiş</label>
            <input type="date" class="form-control" id="toDate">
        </div>
        <button class="btn btn-primary ms-auto" id="btnApply">
            <i class="bi bi-funnel"></i> Filtrele
        </button>
    </div>
</div>

<div class="card card-soft">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr class="text-muted small">
                        <th>Tarih</th>
                        <th>Borç</th>
                        <th>Ödenecek Yer</th>
                        <th class="text-end">Tutar</th>
                        <th class="text-end">Durum</th>
                    </tr>
                </thead>
                <tbody id="body"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/debtTypeDetail.js" asp-append-version="true"></script>
}