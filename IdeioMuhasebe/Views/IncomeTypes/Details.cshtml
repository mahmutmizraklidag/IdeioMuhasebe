@model IdeioMuhasebe.Entities.IncomeType
@{
    ViewData["Title"] = "Gelir Kategorisi Detay";
}
@Html.AntiForgeryToken()

<input type="hidden" id="incomeTypeId" value="@Model.Id" />

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <div class="text-muted small">Gelir Kategorisi</div>
        <div class="fw-semibold fs-5">@Model.Name</div>
    </div>
    <a class="btn btn-light" href="/IncomeTypes"><i class="bi bi-arrow-left"></i> Geri</a>
</div>

<div class="card card-soft mb-3">
    <div class="card-body d-flex flex-wrap gap-2 align-items-end">
        <div>
            <label class="form-label small text-muted">Başlangıç</label>
            <input type="date" class="form-control" id="fromDate">
        </div>
        <div>
            <label class="form-label small text-muted">Bitiş</label>
            <input type="date" class="form-control" id="toDate">
        </div>

        <div style="min-width:220px">
            <label class="form-label small text-muted">Durum</label>
            <select class="form-select" id="statusFilter">
                <option value="total" selected>Toplam</option>
                <option value="paid">Tahsil Edilen</option>
                <option value="unpaid">Tahsil Edilmeyen</option>
            </select>
        </div>

        <button class="btn btn-primary ms-auto" id="btnApply">
            <i class="bi bi-funnel"></i> Filtrele
        </button>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Toplam Gelir</div>
                <div class="fs-4 fw-semibold text-primary" id="cTotal">0 ₺</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Tahsil Edilen</div>
                <div class="fs-4 fw-semibold text-success" id="cReceived">0 ₺</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="card card-soft">
            <div class="card-body">
                <div class="text-muted small">Kalan</div>
                <div class="fs-4 fw-semibold text-danger" id="cRemaining">0 ₺</div>
            </div>
        </div>
    </div>
</div>

<div class="card card-soft">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <div class="fw-semibold">Bu Kategorideki Gelirler</div>
            <a class="btn btn-sm btn-outline-light" href="/Incomes">
                <i class="bi bi-plus-lg"></i> Gelir Ekle/Düzenle
            </a>
        </div>

        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr class="text-muted small">
                        <th>Tarih</th>
                        <th>Gelir</th>
                        <th>Kimden / Kaynak</th>
                        <th class="text-end">Tutar</th>
                        <th class="text-end">Durum</th>
                    </tr>
                </thead>
                <tbody id="rows"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/incomeTypeDetails.js" asp-append-version="true"></script>
}