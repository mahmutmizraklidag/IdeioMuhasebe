@{
    ViewData["Title"] = "Gelir Tahsilat";
}
@Html.AntiForgeryToken()

<div class="card card-soft mb-3">
    <div class="card-body d-flex flex-wrap gap-2 align-items-end">
        <div>
            <label class="form-label small text-muted">Başlangıç</label>
            <input type="date" class="form-control" id="fromDate">
        </div>
        <div>
            <label class="form-label small text-muted">Bitiş</label>
            <input type="date" class="form-control" id="toDate">
        </div>
        <div style="min-width:240px">
            <label class="form-label small text-muted">Kategori</label>
            <select class="form-select" id="typeFilter"></select>
        </div>
        <button class="btn btn-primary ms-auto" id="btnApply">
            <i class="bi bi-funnel"></i> Filtrele
        </button>
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-lg-6">
        <div class="card card-soft payments-panel">
            <div class="card-body">
                <div class="fw-semibold mb-2">Tahsil Edilecekler</div>
                <div id="unpaid" class="kanban-col"></div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card card-soft payments-panel">
            <div class="card-body">
                <div class="fw-semibold mb-2">Tahsil Edilenler</div>
                <div id="paid" class="kanban-col"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
    <script src="~/js/incomePayments.js" asp-append-version="true"></script>
}